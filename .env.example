# HPE OneView connection
OV_HOST=oneview.example.com
OV_USERNAME=monitoring
OV_PASSWORD=changeme
# OV_LOGIN_DOMAIN=LOCAL
OV_API_VERSION=7200

# Exporter settings
OV_SCRAPE_INTERVAL=60
EXPORTER_PORT=9130
# LOG_LEVEL=INFO                # DEBUG, INFO, WARNING, ERROR

# TLS (optional - path to CA bundle for OneView HTTPS cert)
# TLS_CA_BUNDLE=/path/to/ca-chain.pem

# Set to "true" to skip TLS verification (development only!)
# TLS_INSECURE=false
